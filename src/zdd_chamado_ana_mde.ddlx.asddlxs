@UI.facet: [
    /* Gráfico no Header (Este já está funcionando) */
    {
        id: 'HeaderChart',
        purpose: #HEADER,
        type: #CHART_REFERENCE,
        targetQualifier: 'ResumoStatus'
    },
    /* Seção de Conteúdo Principal */
    {
        id: 'GeneralInfo',
        type: #IDENTIFICATION_REFERENCE, // Mudamos para Identification
        label: 'Informações do Status',
        position: 10
    }
  ]





@UI.lineItem: [{ position: 20 }]
@UI.fieldGroup: [{ qualifier: 'Group1', position: 20 }]
@UI.dataPoint: { title: 'Total', criticality: 'StatusCriticality'} // Adicione isso para o gráfico ter um ponto de dados
  TotalChamados;

@UI.fieldGroup: [{ qualifier: 'Group1', position: 10 }] //Incluir agora
@UI.selectionField: [{ position: 10 }]
@UI.lineItem: [{ position: 10 }]
@UI.identification: [{ position: 10 }]
//@UI.textArrangement: #TEXT_ONLY       
  Status;




