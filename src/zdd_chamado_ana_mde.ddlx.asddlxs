@Metadata.layer: #CUSTOMER


@UI.chart: [ {
    qualifier: 'ResumoStatus',
    title: 'Resumo por Status',
    chartType: #DONUT,
    dimensions: [ 'Status' ],
    measures: [ 'TotalChamados' ],
    
    
    dimensionAttributes: [{ 
      dimension: 'Status', 
      role: #CATEGORY


    }],
    measureAttributes: [{ 
      measure: 'TotalChamados', 
      role: #AXIS_1, 
      asDataPoint: true
     
    }]
  } ]


/* 2. Faz o gráfico aparecer na tela inicial (List Report) */
@UI.presentationVariant: [{
    qualifier: 'Default',
    visualizations: [{
       type: #AS_CHART,
        qualifier: 'ResumoStatus'
        
    }]
   }]


annotate entity  ZDD_CHAMADO_ANA
    with 
{
